# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here
WORKSHEET_NAME="Sign In"
HEADER_ROW=5
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json
SHEET_COL_TEST_ID="Test Case ID"
SHEET_COL_TEST_ID_FALLBACK="Test Scenario"
SHEET_COL_CATEGORY="Category"
SHEET_COL_TEST_DATA="Test Data"
SHEET_COL_EXPECTED_RESULT="Expected Result"
SHEET_COL_STATUS="Status"
SHEET_COL_API_STATUS="API Status"
SHEET_COL_API_AUTOMATION="API Automation"
SHEET_COL_COMMENT_BACKEND="Comment - Backend"
# Strict write whitelist (comma-separated): api_status, api_automation, comment_backend
SHEET_WRITE_COLUMNS="api_status,api_automation,comment_backend"

# API
BASE_URL=https://sixsense-team-pulse-backend-test.onrender.com
LOGIN_ENDPOINT=/auth/login

# Login credentials (substituted into test data placeholders)
EMAIL=your-test-email@example.com
PASSWORD=your-test-password

# Set true to write API Status, API Automation, and Comment - Backend after each test run
WRITE_RESULTS=false
REPORT_HTML_PATH=test/signin/report.html
TEST_CATEGORIES=API,Both

# Hoppscotch (agent-hoppscotch CLI)
# Cloud: https://hoppscotch.io/backend/graphql
# Self-hosted: https://your-domain/graphql
HOPPSCOTCH_GRAPHQL_ENDPOINT=https://hoppscotch.io/backend/graphql
HOPPSCOTCH_SESSION_COOKIE=
HOPPSCOTCH_TEAM_ID=
HOPPSCOTCH_COLLECTION_ID=
HOPPSCOTCH_COLLECTION_NAME="API Automation"
HOPPSCOTCH_DEV_COLLECTION_ID=

# Sync Google Sheet sign-in cases to Hoppscotch before run-sign-in-qa (true/false)
SYNC_HOPPSCOTCH=true

# Hoppscotch team environment for sign-in variables (BASE_URL, EMAIL, PASSWORD, etc.)
HOPPSCOTCH_ENV_NAME="Sign In - Test"
# HOPPSCOTCH_ENV_ID=
