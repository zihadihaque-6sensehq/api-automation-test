# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here
WORKSHEET_NAME="Sign In"
HEADER_ROW=5
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json
SHEET_COL_TEST_ID="Test Case ID"
SHEET_COL_TEST_ID_FALLBACK="Test Scenario"
SHEET_COL_CATEGORY="Category"
SHEET_COL_TEST_DATA="Test Data"
SHEET_COL_ENDPOINT="API Endpoint"
# Fallback if a tab still uses "Endpoint"
# SHEET_COL_ENDPOINT_FALLBACK=Endpoint
SHEET_COL_QUERY_PARAMS="Query Parameter"
# SHEET_COL_QUERY_PARAMS_FALLBACK="Query Parameters,Query Params"
SHEET_COL_EXPECTED_RESULT="Expected Result"
SHEET_COL_STATUS="Status"
SHEET_COL_API_STATUS="API Status"
SHEET_COL_COMMENT="Comment"
# Legacy alias (optional):
# SHEET_COL_COMMENT_BACKEND="Comment"
# Strict write whitelist (comma-separated): api_status, comment_backend
SHEET_WRITE_COLUMNS="api_status,comment_backend"

# API Endpoint column format (multi-line):
# Public
# POST
# /auth/login
# Protected
# GET
# /feedback
# Protected routes sync with Bearer auth using team env <<bearer_token>>.

BASE_URL=https://sixsense-team-pulse-backend-test.onrender.com
LOGIN_ENDPOINT=/auth/login

# Login credentials (substituted into test data placeholders)
EMAIL=your-test-email@example.com
PASSWORD=your-test-password

# Set true to write API Status and Comment after each test run
WRITE_RESULTS=false
REPORT_HTML_PATH=test/signin/report.html
TEST_CATEGORIES=API,Both

# Hoppscotch (agent-hoppscotch CLI — sync/create endpoints + scripts)
HOPPSCOTCH_GRAPHQL_ENDPOINT=https://hoppscotch.io/backend/graphql
HOPPSCOTCH_SESSION_COOKIE=
HOPPSCOTCH_TEAM_ID=

# Request collections: one per worksheet tab under TEST folder (TEST → sign-in, registration, …)
# HOPPSCOTCH_TEST_FOLDER_NAME=TEST
# HOPPSCOTCH_TEST_FOLDER_ID=

# Team environment variables — single shared env for all modules (includes bearer_token)
HOPPSCOTCH_ENV_NAME=Test
# HOPPSCOTCH_ENV_ID=

# Hoppscotch CLI (hopp test — run collection + pw scripts)
HOPPSCOTCH_PAT=
# HOPPSCOTCH_SERVER_URL=

# Agent poll (npm run agent:poll)
# AGENT_ALL_WORKSHEETS=true
# SHEET_SKIP_WORKSHEETS=
# AGENT_PROCESS_ALL=false
